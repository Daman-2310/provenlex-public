{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install --legacy-peer-deps",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://daman23-genesis-swarm-api.hf.space"
  },
  "crons": [
    {
      "path": "/api/cron/morning",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "30 7 * * *"
    }
  ],
  "functions": {
    "app/api/cron/**/route.ts": {
      "maxDuration": 60
    },
    "app/api/analyze/**/route.ts": {
      "maxDuration": 30
    }
  }
}
