# Genesis Swarm — Environment Variables
# Copy to .env and fill in your credentials.
# Never commit .env to version control.

# ── Security (REQUIRED in production) ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GENESIS_JWT_SECRET=change-me-to-a-strong-random-string-in-production

# ── User accounts (optional — uses dev defaults if not set) ──────────────────
# JSON map: {"username": {"hash": "<bcrypt>", "roles": ["admin","operator","viewer"]}}
# Generate bcrypt hash: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('your_password'))"
# GENESIS_USERS={"admin":{"hash":"$2b$12$...","roles":["admin","operator","viewer"]}}

# ── AI — Claude (optional, enables JARVIS AI chat) ───────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Live AIS vessel tracking (optional, enables real vessel data in CargoBot) ─
# Register free at: https://aisstream.io
AISSTREAM_API_KEY=

# ── Email alerts (optional) ───────────────────────────────────────────────────
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
GENESIS_ALERT_EMAIL=alerts@yourfund.com
GENESIS_SMTP_USER=your@gmail.com
GENESIS_SMTP_PASS=your_app_password
GENESIS_SMTP_HOST=smtp.gmail.com
GENESIS_SMTP_PORT=587

# ── Slack alerts (optional) ───────────────────────────────────────────────────
# GENESIS_SLACK_WEBHOOK=https://hooks.slack.com/services/...

# ── Webhooks (optional — signed event delivery to external systems) ──────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# GENESIS_WEBHOOK_SECRET=change-me-to-a-strong-random-string

# ── Redis (required for multi-replica deployments) ───────────────────────────
# Generate standalone: docker run -d -p 6379:6379 redis:7-alpine
# GENESIS_REDIS_URL=redis://localhost:6379/0
# With password: redis://:your_password@localhost:6379/0

# ── Database (optional — defaults to ./cases.db) ─────────────────────────────
# GENESIS_CASE_DB_PATH=/data/cases.db

# ── Grafana (optional, for monitoring profile) ────────────────────────────────
# GRAFANA_ADMIN_PASSWORD=change-me
